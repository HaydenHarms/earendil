<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Earendil Advisory</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #0a1628;
    --navy-deep: #07111f;
    --gold: #c4a359;
    --gold-dim: rgba(196,163,89,0.4);
    --cream: #e8dfc8;
    --cream-dim: rgba(232,223,200,0.55);
    --cream-mute: rgba(232,223,200,0.35);
    --rule: rgba(196,163,89,0.15);
  }
  html { scroll-behavior: smooth; }
  body {
    background: #000;
    color: var(--cream);
    font-family: 'Jost', sans-serif;
    font-weight: 300;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  /* FULL PAGE GALAXY CANVAS */
  #bgCanvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.55;
    pointer-events: none;
  }

  /* Everything sits above the canvas */
  nav, .hero, .stats, .services, .philosophy, footer {
    position: relative;
    z-index: 1;
  }

  /* Navy tint over star field so text stays readable */
  nav { background: rgba(7,17,31,0.55); }
  .hero { background: rgba(7,17,31,0.0); }
  .stats { background: rgba(7,17,31,0.72); }
  .services { background: rgba(7,17,31,0.68); }
  .philosophy { background: rgba(7,17,31,0.65); }
  footer { background: rgba(7,17,31,0.8); }

  /* ANIMATIONS */
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroFade {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow  { opacity: 0; animation: heroFade 0.7s ease 0.2s forwards; }
  .hero-headline { opacity: 0; animation: heroFade 0.7s ease 0.35s forwards; }
  .hero-sub      { opacity: 0; animation: heroFade 0.7s ease 0.55s forwards; }
  .hero-cta      { opacity: 0; animation: heroFade 0.7s ease 0.7s forwards; }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.75s ease, transform 0.75s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .cursor {
    display: inline-block;
    width: 2px;
    height: 0.8em;
    background: var(--gold);
    margin-left: 2px;
    vertical-align: middle;
    animation: blink 0.8s step-end infinite;
  }

  /* NAV */
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 48px;
    border-bottom: 0.5px solid var(--rule);
  }
  .wordmark {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .wordmark span {
    font-style: italic;
    font-weight: 400;
    color: var(--cream);
    text-transform: none;
    margin-left: 6px;
  }
  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cream-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-cta {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--navy);
    background: var(--gold);
    border: none;
    padding: 11px 26px;
    cursor: pointer;
    font-weight: 400;
    transition: opacity 0.2s;
  }
  .nav-cta:hover { opacity: 0.88; }

  /* HERO — full viewport, single panel, Palantir-style */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 48px;
    position: relative;
    border-bottom: 0.5px solid var(--rule);
  }
  .hero-left {
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 720px;
  }
  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
  }
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 54px;
    font-weight: 400;
    line-height: 1.08;
    color: var(--cream);
    margin-bottom: 28px;
  }
  h1 em { font-style: italic; color: var(--gold); }
  .hero-sub {
    font-size: 14px;
    line-height: 1.85;
    color: var(--cream-dim);
    max-width: 380px;
    margin-bottom: 44px;
  }
  .cta-row { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
  .btn-primary {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--navy);
    background: var(--gold);
    border: none;
    padding: 15px 34px;
    cursor: pointer;
    font-weight: 400;
    transition: opacity 0.2s;
  }
  .btn-primary:hover { opacity: 0.88; }
  .btn-ghost {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cream-dim);
    background: transparent;
    border: 0.5px solid rgba(232,223,200,0.22);
    padding: 15px 34px;
    cursor: pointer;
    font-weight: 400;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(196,163,89,0.5); color: var(--gold); }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
  }

  /* STATS */
  .stats {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    border-bottom: 0.5px solid var(--rule);
  }
  .stat { padding: 36px 48px; border-right: 0.5px solid var(--rule); }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px;
    font-weight: 500;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
  }
  .stat-label { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cream-mute); }

  /* SERVICES */
  .services { padding: 72px 48px; }
  .section-eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 48px;
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .section-eyebrow::after { content: ''; height: 0.5px; flex: 1; background: var(--rule); }
  .service-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1px;
    background: var(--rule);
  }
  .service-card { background: var(--navy); padding: 40px 36px; transition: background 0.25s; }
  .service-card:hover { background: #0d1d33; }
  .service-num { font-family: 'Cormorant Garamond', serif; font-size: 12px; letter-spacing: 0.12em; color: var(--gold-dim); margin-bottom: 22px; }
  .service-title { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 500; color: var(--cream); margin-bottom: 16px; line-height: 1.2; }
  .service-desc { font-size: 13px; line-height: 1.85; color: rgba(232,223,200,0.42); }

  /* PHILOSOPHY */
  .philosophy {
    border-top: 0.5px solid var(--rule);
    border-bottom: 0.5px solid var(--rule);
    padding: 56px 48px;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
    align-items: center;
  }
  .phil-label { font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold-dim); }
  .phil-quote { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 400; font-style: italic; line-height: 1.5; color: var(--cream); }
  .phil-quote em { color: var(--gold); font-style: normal; }

  /* FOOTER */
  footer {
    padding: 28px 48px;
    border-top: 0.5px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-copy { font-size: 11px; color: rgba(232,223,200,0.25); letter-spacing: 0.08em; }
  .footer-tagline { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 15px; color: rgba(196,163,89,0.45); }

  /* MOBILE */
  @media (max-width: 700px) {
    nav { padding: 20px 24px; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; }
    .hero-left { padding: 48px 24px; border-right: none; border-bottom: 0.5px solid var(--rule); }
    .hero-right { min-height: 280px; }
    h1 { font-size: 38px; }
    .stats { grid-template-columns: 1fr; }
    .stat { border-right: none; border-bottom: 0.5px solid var(--rule); padding: 28px 24px; }
    .stat:last-child { border-bottom: none; }
    .services { padding: 48px 24px; }
    .service-grid { grid-template-columns: 1fr; }
    .philosophy { grid-template-columns: 1fr; gap: 24px; padding: 48px 24px; }
    footer { flex-direction: column; gap: 12px; padding: 24px; text-align: center; }
  }
</style>
</head>
