    vec2 mPosUV=(uMouse*uResolution.xy-focalPx)/uResolution.y;
    float mDist=length(uv-mPosUV);
    vec2 rep=normalize(uv-mPosUV)*(uRepulsionStrength/(mDist+0.1));
    uv+=rep*0.05*uMouseActiveFactor;
  } else {
    uv+=mouseNorm*0.1*uMouseActiveFactor;
  }
